# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Explicitly declare text files
*.py text diff=python
*.ts text diff=typescript
*.tsx text diff=typescript
*.js text diff=javascript
*.jsx text diff=javascript
*.json text
*.jsonc text
*.json5 text
*.yaml text
*.yml text
*.toml text
*.ini text
*.cfg text
*.md text diff=markdown
*.mdx text diff=markdown
*.html text diff=html
*.htm text diff=html
*.css text diff=css
*.scss text diff=css
*.sql text
*.sh text eol=lf diff=bash
*.bash text eol=lf diff=bash
*.zsh text eol=lf diff=bash
*.env text
*.editorconfig text
*.gitignore text
*.gitattributes text
*.pre-commit-config.yaml text

# Windows-specific files use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
*.psm1 text eol=crlf
*.psd1 text eol=crlf
*.sln text eol=crlf
*.csproj text eol=crlf

# Denote files that are truly binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.avif binary
*.bmp binary
*.tiff binary
*.tif binary
*.mp4 binary
*.webm binary
*.mov binary
*.avi binary
*.wmv binary
*.flv binary
*.mkv binary
*.ogg binary
*.mp3 binary
*.wav binary
*.flac binary
*.aac binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.bz2 binary
*.xz binary
*.7z binary
*.rar binary

# Git LFS patterns
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.gif filter=lfs diff=lfs merge=lfs -text
*.ico filter=lfs diff=lfs merge=lfs -text
