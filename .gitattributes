# Linguist overrides
packages/electron/src/** linguist-vendored=false linguist-generated=false
packages/ui/src/components/generated/** linguist-generated=true
*.min.js linguist-generated=true
*.min.css linguist-generated=true
package-lock.json linguist-generated=true
pnpm-lock.yaml linguist-generated=true
yarn.lock linguist-generated=true

# Syntax highlighting hints
*.py linguist-language=Python
*.ts linguist-language=TypeScript
*.tsx linguist-language=TSX
*.js linguist-language=JavaScript
*.jsx linguist-language=JSX

# Diff drivers
*.py diff=python
*.ts diff=typescript
*.tsx diff=typescript
*.js diff=javascript
*.jsx diff=javascript
*.html diff=html
*.css diff=css
*.md diff=markdown
*.sh diff=bash

# Archive handling
*.tar binary
*.gz binary
*.tgz binary
*.bz2 binary
*.xz binary
*.zip binary

# Ensure lockfiles are not modified
package-lock.json -diff linguist-generated=true
pnpm-lock.yaml -diff linguist-generated=true
yarn.lock -diff linguist-generated=true
poetry.lock -diff linguist-generated=true
