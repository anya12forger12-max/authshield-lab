# =============================================================================
# AuthShield Lab - Backend Environment Configuration
# =============================================================================
# Copy this file to .env and modify the values as needed.
# NEVER commit the .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------

# Application mode: demo | student | instructor | admin | developer
APP_MODE=developer

# Application name displayed in the UI
APP_NAME=AuthShield Lab

# Application version
APP_VERSION=1.0.0-alpha.1

# -----------------------------------------------------------------------------
# Server Settings
# -----------------------------------------------------------------------------

# Host to bind to (MUST be localhost for security)
APP_HOST=127.0.0.1

# Port for the backend API server
APP_PORT=8000

# Reload on code changes (development only)
APP_RELOAD=true

# Log level: debug | info | warning | error | critical
APP_LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Security Settings
# -----------------------------------------------------------------------------

# Secret key for JWT token signing (CHANGE THIS IN PRODUCTION)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
APP_SECRET_KEY=dev-secret-key-change-in-production

# JWT algorithm
APP_JWT_ALGORITHM=HS256

# Access token expiration (minutes)
APP_ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token expiration (days)
APP_REFRESH_TOKEN_EXPIRE_DAYS=7

# bcrypt work factor (minimum 10, recommended 12+)
APP_BCRYPT_ROUNDS=12

# Maximum login attempts before lockout
APP_MAX_LOGIN_ATTEMPTS=5

# Account lockout duration (minutes)
APP_LOCKOUT_DURATION_MINUTES=15

# Password history size (number of previous passwords to remember)
APP_PASSWORD_HISTORY_SIZE=12

# -----------------------------------------------------------------------------
# Database Settings
# -----------------------------------------------------------------------------

# SQLite database file path
APP_DB_PATH=./data/app.db

# Database backup directory
APP_DB_BACKUP_DIR=./data/backups

# Enable WAL mode for better concurrency
APP_DB_WAL_MODE=true

# Connection pool size (SQLite: 1)
APP_DB_POOL_SIZE=1

# -----------------------------------------------------------------------------
# CORS Settings
# -----------------------------------------------------------------------------

# Allowed origins (comma-separated list of URLs)
APP_CORS_ORIGINS=["http://localhost:5173","http://localhost:8000","http://localhost:3000"]

# Allow credentials (cookies, authorization headers)
APP_CORS_ALLOW_CREDENTIALS=true

# Allowed methods
APP_CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","PATCH","OPTIONS"]

# Allowed headers
APP_CORS_ALLOW_HEADERS=["*"]

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------

# Enable rate limiting
APP_RATE_LIMIT_ENABLED=true

# Default rate limit (requests per minute)
APP_RATE_LIMIT_DEFAULT=100

# Login rate limit (requests per minute)
APP_RATE_LIMIT_LOGIN=5

# Registration rate limit (requests per 5 minutes)
APP_RATE_LIMIT_REGISTER=3

# Password reset rate limit (requests per 15 minutes)
APP_RATE_LIMIT_PASSWORD_RESET=3

# -----------------------------------------------------------------------------
# Session Settings
# -----------------------------------------------------------------------------

# Session timeout (minutes)
APP_SESSION_TIMEOUT_MINUTES=30

# Maximum concurrent sessions per user
APP_MAX_SESSIONS=3

# Enable single session mode (one session per user)
APP_SINGLE_SESSION=false

# Session cookie name
APP_SESSION_COOKIE_NAME=authshield_session

# Session cookie secure (HTTPS only)
APP_SESSION_COOKIE_SECURE=false

# Session cookie same-site policy
APP_SESSION_COOKIE_SAMESITE=strict

# -----------------------------------------------------------------------------
# Logging Settings
# -----------------------------------------------------------------------------

# Log directory
APP_LOG_DIR=./logs

# Log file name
APP_LOG_FILE=app.log

# Access log file name
APP_ACCESS_LOG_FILE=access.log

# Audit log file name
APP_AUDIT_LOG_FILE=audit.log

# Log max file size (MB)
APP_LOG_MAX_SIZE_MB=10

# Log backup count
APP_LOG_BACKUP_COUNT=5

# Enable console logging
APP_LOG_CONSOLE=true

# Enable file logging
APP_LOG_FILE_ENABLED=true

# -----------------------------------------------------------------------------
# File Upload Settings
# -----------------------------------------------------------------------------

# Maximum upload size (MB)
APP_MAX_UPLOAD_SIZE_MB=10

# Allowed upload extensions
APP_ALLOWED_EXTENSIONS=[".csv",".json",".txt",".pdf",".png",".jpg",".jpeg"]

# Upload directory
APP_UPLOAD_DIR=./uploads

# -----------------------------------------------------------------------------
# Attack Simulation Settings
# -----------------------------------------------------------------------------

# Maximum concurrent attacks
APP_MAX_CONCURRENT_ATTACKS=5

# Default attack timeout (seconds)
APP_ATTACK_TIMEOUT_SECONDS=300

# Maximum brute force attempts per simulation
APP_MAX_BRUTE_FORCE_ATTEMPTS=1000

# Attack log retention (days)
APP_ATTACK_LOG_RETENTION_DAYS=365

# -----------------------------------------------------------------------------
# Defense Settings
# -----------------------------------------------------------------------------

# Enable anomaly detection
APP_ANOMALY_DETECTION=true

# Anomaly detection sensitivity (low | medium | high)
APP_ANOMALY_SENSITIVITY=medium

# Defense event retention (days)
APP_DEFENSE_EVENT_RETENTION_DAYS=90

# -----------------------------------------------------------------------------
# Learning Center Settings
# -----------------------------------------------------------------------------

# Enable progress tracking
APP_PROGRESS_TRACKING=true

# Quiz pass threshold (percentage)
APP_QUIZ_PASS_THRESHOLD=70

# Certificate validity (days)
APP_CERTIFICATE_VALIDITY_DAYS=365

# -----------------------------------------------------------------------------
# Backup Settings
# -----------------------------------------------------------------------------

# Enable automatic backups
APP_AUTO_BACKUP=false

# Backup schedule (cron expression: minute hour day month weekday)
APP_BACKUP_SCHEDULE=0 2 * * *

# Backup retention (days)
APP_BACKUP_RETENTION_DAYS=30

# Maximum backup count
APP_MAX_BACKUPS=30

# -----------------------------------------------------------------------------
# Notification Settings
# -----------------------------------------------------------------------------

# Enable notifications
APP_NOTIFICATIONS=true

# Notification sound
APP_NOTIFICATION_SOUND=true

# Notification duration (seconds)
APP_NOTIFICATION_DURATION=5

# -----------------------------------------------------------------------------
# Internationalization
# -----------------------------------------------------------------------------

# Default language
APP_DEFAULT_LANGUAGE=en

# Supported languages
APP_SUPPORTED_LANGUAGES=["en","es","fr","de","ja"]

# -----------------------------------------------------------------------------
# Development Settings
# -----------------------------------------------------------------------------

# Enable debug mode
APP_DEBUG=true

# Enable API documentation
APP_DOCS_ENABLED=true

# API documentation URL
APP_DOCS_URL=/docs

# ReDoc documentation URL
APP_REDOC_URL=/redoc

# Enable CORS debug logging
APP_CORS_DEBUG=false

# Enable request logging
APP_REQUEST_LOGGING=true

# Enable profiling
APP_PROFILING=false
