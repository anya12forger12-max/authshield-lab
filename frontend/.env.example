# =============================================================================
# AuthShield Lab - Frontend Environment Configuration
# =============================================================================
# Copy this file to .env and modify the values as needed.
# NEVER commit the .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------

# Backend API URL
VITE_API_URL=http://localhost:8000

# WebSocket URL for real-time updates
VITE_WS_URL=ws://localhost:8000/ws

# API timeout (milliseconds)
VITE_API_TIMEOUT=30000

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------

# Application mode: demo | student | instructor | admin | developer
VITE_APP_MODE=developer

# Application name
VITE_APP_NAME=AuthShield Lab

# Application version
VITE_APP_VERSION=1.0.0-alpha.1

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------

# Enable analytics tracking (development only)
VITE_ENABLE_ANALYTICS=false

# Enable debug mode
VITE_ENABLE_DEBUG=true

# Enable experimental features
VITE_ENABLE_EXPERIMENTAL=false

# Enable WebSocket real-time updates
VITE_ENABLE_WEBSOCKET=true

# Enable service worker (PWA)
VITE_ENABLE_SERVICE_WORKER=false

# -----------------------------------------------------------------------------
# Theme Settings
# -----------------------------------------------------------------------------

# Default theme: light | dark | high-contrast | dyslexia | solarized
VITE_DEFAULT_THEME=light

# Default font size: sm | md | lg | xl | 2xl
VITE_DEFAULT_FONT_SIZE=md

# Enable reduced motion by default
VITE_DEFAULT_REDUCED_MOTION=false

# -----------------------------------------------------------------------------
# Accessibility Settings
# -----------------------------------------------------------------------------

# Enable screen reader optimizations
VITE_SCREEN_READER_MODE=false

# Enable high contrast mode
VITE_HIGH_CONTRAST_MODE=false

# Enable keyboard shortcuts display
VITE_SHOW_SHORTCUTS=true

# -----------------------------------------------------------------------------
# Internationalization
# -----------------------------------------------------------------------------

# Default language
VITE_DEFAULT_LANGUAGE=en

# Supported languages
VITE_SUPPORTED_LANGUAGES=en,es,fr,de,ja

# -----------------------------------------------------------------------------
# UI Settings
# -----------------------------------------------------------------------------

# Enable sidebar collapse by default
VITE_SIDEBAR_COLLAPSED=false

# Enable breadcrumbs
VITE_SHOW_BREADCRUMBS=true

# Enable notifications
VITE_ENABLE_NOTIFICATIONS=true

# Notification duration (milliseconds)
VITE_NOTIFICATION_DURATION=5000

# Maximum notifications to display
VITE_MAX_NOTIFICATIONS=5

# -----------------------------------------------------------------------------
# Learning Center Settings
# -----------------------------------------------------------------------------

# Enable quiz timer
VITE_QUIZ_TIMER_ENABLED=true

# Quiz timer duration (seconds)
VITE_QUIZ_TIMER_DURATION=600

# Enable progress persistence
VITE_PERSIST_PROGRESS=true

# -----------------------------------------------------------------------------
# Developer Settings
# -----------------------------------------------------------------------------

# Enable developer tools
VITE_DEVTOOLS_ENABLED=true

# Enable React DevTools
VITE_REACT_DEVTOOLS=true

# Enable performance monitoring
VITE_PERF_MONITORING=false

# Enable source maps in production
VITE_SOURCEMAPS=false

# -----------------------------------------------------------------------------
# Build Settings
# -----------------------------------------------------------------------------

# Enable code splitting
VITE_CODE_SPLITTING=true

# Enable gzip compression
VITE_GZIP_ENABLED=true

# Enable bundle analysis
VITE_ANALYZE=false
